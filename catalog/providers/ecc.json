    "codex",
    "claude"
  ],
  "allowedSkills": [
    "tdd-workflow",
    "verification-loop",
    "coding-standards",
    "backend-patterns",
    "security-review",
    "api-design",
    "documentation-lookup",
    "frontend-patterns",
    "python-patterns",
    "python-testing",
    "database-migrations"
  ]
}
